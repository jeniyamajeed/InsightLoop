# Copy to .env before `docker compose up`.
# In production, generate a strong random JWT_SECRET (>= 32 chars).

MYSQL_ROOT_PASSWORD=root
MYSQL_USER=insightloop
MYSQL_PASSWORD=insightloop

# HS256 shared secret used by every service to verify JWTs.
# Must be identical across gateway + all services.
JWT_SECRET=change_me_to_a_long_random_string_at_least_32_bytes_long_please

# Access token lifetime in milliseconds (8 hours).
JWT_EXPIRATION_MS=28800000
